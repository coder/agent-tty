{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "semi": true,
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "coverage",
    "design",
    "dist",
    "node_modules",
