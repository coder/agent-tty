{
  "name": "agent-terminal",
  "version": "0.1.0",
  "description": "Terminal automation CLI for AI agents and humans",
  "keywords": [
    "terminal",
    "tui",
    "automation",
    "ai",
    "tanstack-intent"
  ],
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "bin": {
    "agent-terminal": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "skills",
    "!skills/_artifacts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-renderer-assets.mjs",
    "clean": "rimraf coverage dist *.tsbuildinfo",
    "cli": "tsx src/cli/main.ts",
    "doctor": "tsx src/cli/main.ts doctor",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "intent:validate": "npx @tanstack/intent@latest validate",
    "lint": "eslint src test vitest.config.ts --max-warnings=0",
    "lint:fix": "eslint src test vitest.config.ts --fix",
    "prepublishOnly": "npm run verify",
    "review-bundle": "tsx src/tools/review-bundle.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate-bundle": "tsx src/tools/validate-bundle.ts",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "version:json": "tsx src/cli/main.ts version --json"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2"
  },
  "dependencies": {
    "commander": "14.0.3",
    "ghostty-web": "0.4.0",
    "node-pty": "1.1.0",
    "playwright": "1.58.2",
    "ulid": "3.0.2",
    "zod": "4.3.6"
  }
}
