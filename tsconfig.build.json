{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": ".tsconfig.build.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "test/**/*.ts",
    "test/**/*.tsx",
    "dist",
    "coverage",
    "node_modules"
  ]
}
