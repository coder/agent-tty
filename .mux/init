#!/usr/bin/env bash
set -euo pipefail

echo "[mux:init] runtime: ${MUX_RUNTIME:-unknown}"
echo "[mux:init] workspace: ${MUX_WORKSPACE_NAME:-unknown}"

_mux_mise_bin=""
if command -v mise >/dev/null 2>&1; then
  _mux_mise_bin="$(command -v mise)"
elif [ -x "$HOME/.local/bin/mise" ]; then
  _mux_mise_bin="$HOME/.local/bin/mise"
elif [ -x "/opt/homebrew/bin/mise" ]; then
  _mux_mise_bin="/opt/homebrew/bin/mise"
elif [ -x "/usr/local/bin/mise" ]; then
  _mux_mise_bin="/usr/local/bin/mise"
fi

if [ -z "$_mux_mise_bin" ]; then
  echo "[mux:init] mise not found; skipping workspace bootstrap"
  echo "[mux:init] install mise to enable automatic toolchain setup"
  exit 0
fi

echo "[mux:init] using mise at $_mux_mise_bin"

_mux_mise_config="$PWD/mise.toml"
if [ -f "$_mux_mise_config" ]; then
  # Worktree workspaces live at unique paths, so mise treats each workspace copy
  # as a newly untrusted config until it is explicitly trusted.
  "$_mux_mise_bin" trust -y "$_mux_mise_config" >/dev/null 2>&1 || true
fi

"$_mux_mise_bin" install
"$_mux_mise_bin" exec -- aube exec playwright install chromium

unset _mux_mise_bin
unset _mux_mise_config
